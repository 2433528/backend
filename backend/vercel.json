{
    "builds":[
        {
            "src":"backend/wsgi.py",
            "use":"@vercel/python"
        },

        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],

    "routes":[
        {
        "src": "/static/(.*)",
        "dest": "/static/$1"
        },

        {
            "src":"/(.*)",
            "dest":"backend/wsgi.py"
        }
    ]
}